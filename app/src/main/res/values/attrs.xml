<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Custom attributes for XML -->
    <!-- BaseControl attributes-->
    <declare-styleable name="BaseControlView">
        <attr name="defaultSize" format="dimension"/>
        <attr name="baseColor" format="color"/>
        <attr name="handleColor" format="color"/>
        <attr name="centerDotColor" format="color"/>
        <attr name="baseRadiusRatio" format="float"/>
        <attr name="handleRadiusRatio" format="float" />
    </declare-styleable>

    <!-- Attributes extending Base for Joystick -->
    <declare-styleable name="JoystickView">
    </declare-styleable>

    <!-- Attributes extending Base for Gyro -->
    <declare-styleable name="GyroView">
        <attr name="deadZoneRatio" format="float" />
        <attr name="deadZoneColor" format="color" />
    </declare-styleable>

</resources>