<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:gravity="center"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.hbrs.Views.GyroView
        android:id="@+id/gyroView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:gyroBaseColor="#444"
        app:knobColor="#00BCD4"
        app:gyroCenterDotColor="#00FF00"
        app:knobRadiusRatio="0.12"
        app:maxPitchDisplacementRatio="0.7" />
    <TextView
        android:id="@+id/tv_displacement"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Displacement"/>

</LinearLayout>